# FinMonitor 환경변수 설정
# 이 파일을 .env 로 복사한 후 실제 값으로 채워주세요.
#   cp .env.example .env

# ─── 서버 설정 ────────────────────────────────────────────
PORT=3000

# ─── PostgreSQL 설정 ──────────────────────────────────────
# DATABASE_URL을 우선 사용하고, 없으면 개별 PG* 변수를 사용합니다.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/socopsasm
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=socopsasm

# ─── ASM 툴 경로(선택) ─────────────────────────────────────
# 기본값: <project>/tools
# 예) /Users/leejiyu/Desktop/hanwha/tools
ASM_TOOLS_DIR=
# Masscan 권한 전략:
#   auto    = root/capability 있으면 실행, 없으면 skip
#   require = 권한 없으면 실패 처리
#   disabled= 항상 비활성화
ASM_MASSCAN_MODE=auto
# 수동 셸에서만 필요 시 1로 설정 (PM2에서는 보통 0 권장)
ASM_MASSCAN_ALLOW_SUDO=0

# ─── Blackbox Exporter ────────────────────────────────────
BLACKBOX_URL=http://localhost:9115
BLACKBOX_MODULE=http_2xx
PROBE_TIMEOUT_MS=15000

# ─── 점검 주기 (cron 형식) ────────────────────────────────
# 기본값: 매 1분마다
CRON_SCHEDULE=* * * * *

# ─── Gmail SMTP 알림 설정 ─────────────────────────────────
# 1. Google 계정 → 보안 → 2단계 인증 활성화
# 2. 앱 비밀번호 생성 (16자리) → SMTP_PASS에 입력
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=FinMonitor <your-email@gmail.com>
